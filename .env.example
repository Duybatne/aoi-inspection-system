# System Configuration
ENVIRONMENT=development
LOG_LEVEL=INFO

# Database Configuration
DB_HOST=localhost
DB_PORT=5433
DB_USER=aoi_user
DB_PASSWORD=aoi_password
DB_NAME=aoi_db
DATABASE_URL=postgresql://aoi_user:aoi_password@localhost:5433/aoi_db

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# RabbitMQ Configuration
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=aoi_mq_user
RABBITMQ_PASSWORD=aoi_mq_password
CELERY_BROKER_URL=amqp://aoi_mq_user:aoi_mq_password@localhost:5672//

# MinIO Configuration
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=minio_admin_password
MINIO_SECURE=false
MINIO_BUCKET_NAME=aoi-pcb-images

# Hardware Configuration (Mock / Real)
CAMERA_TYPE=mock # Options: mock, basler, allied
CAMERA_ID=0
LIGHTING_PORT=/dev/ttyUSB0
LIGHTING_BAUDRATE=9600

# AI Model Configuration (Local Engine Paths)
YOLO_MODEL_PATH=ml/models/yolov11-m.engine
CONFIDENCE_THRESHOLD=0.5
RECALL_MIN_THRESHOLD=0.95

# Cloud Inference (Roboflow Cloud API)
# Set your Roboflow API key to enable Cloud Inference, otherwise it defaults to MockDetector
ROBOFLOW_API_KEY=
ROBOFLOW_MODEL_ID=pcb-defect-detection/1
ROBOFLOW_API_URL=https://detect.roboflow.com

# Verdict Engine Thresholds
VERDICT_HIGH_CONF_THRESHOLD=0.85
VERDICT_MAX_DEFECT_COUNT=3

# Image Quality Check Validation
IMAGE_BLUR_THRESHOLD=100.0
IMAGE_BRIGHTNESS_MIN=30.0
IMAGE_BRIGHTNESS_MAX=230.0
